#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"

# ---------------------------------------------------------------------------
# Discover locale subdirs from frontend/messages/ (excluding 'en')
# Used to build the exclusion list for docs locale subdirs.
# ---------------------------------------------------------------------------
LOCALE_EXCLUDE_PATTERN=""
if [ -d "$ROOT/frontend/messages" ]; then
  for locale_dir in "$ROOT/frontend/messages"/*/; do
    locale_name="$(basename "$locale_dir")"
    if [ "$locale_name" != "en" ]; then
      if [ -z "$LOCALE_EXCLUDE_PATTERN" ]; then
        LOCALE_EXCLUDE_PATTERN="^docs/${locale_name}/"
      else
        LOCALE_EXCLUDE_PATTERN="${LOCALE_EXCLUDE_PATTERN}|^docs/${locale_name}/"
      fi
    fi
  done
fi

# ---------------------------------------------------------------------------
# Detect staged EN source files
# ---------------------------------------------------------------------------
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^frontend/messages/en/.*\.json$' || true)

# MDX files under docs/ but NOT under any locale subdir
RAW_MDX=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^docs/.*\.mdx$' || true)

if [ -n "$RAW_MDX" ] && [ -n "$LOCALE_EXCLUDE_PATTERN" ]; then
  STAGED_MDX=$(echo "$RAW_MDX" | grep -vE "$LOCALE_EXCLUDE_PATTERN" || true)
else
  STAGED_MDX="$RAW_MDX"
fi

STAGED_README=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^README\.md$' || true)

STAGED_WEB_PY=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^src/fim_one/web/.*\.py$' || true)

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^src/fim_one/.*\.py$' || true)

# ---------------------------------------------------------------------------
# Skip hook if nothing relevant is staged
# ---------------------------------------------------------------------------
if [ -z "$STAGED_JSON" ] && [ -z "$STAGED_MDX" ] && [ -z "$STAGED_README" ] && [ -z "$STAGED_WEB_PY" ] && [ -z "$STAGED_PY" ]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Re-generate OpenAPI spec if web routes changed
# ---------------------------------------------------------------------------
if [ -n "$STAGED_WEB_PY" ]; then
  echo "openapi: regenerating docs/openapi.json..."
  cd "$ROOT"
  uv run python scripts/export_openapi.py 2>/dev/null
  git add docs/openapi.json
fi

# ---------------------------------------------------------------------------
# Run the translation script (skip if only web py changed, no docs)
# ---------------------------------------------------------------------------
if [ -n "$STAGED_JSON" ] || [ -n "$STAGED_MDX" ] || [ -n "$STAGED_README" ]; then
  echo "i18n: translating changed files..."
  cd "$ROOT"
  GIT_HOOK=1 uv run scripts/translate.py
fi

# ---------------------------------------------------------------------------
# Incremental mypy type check on staged Python files
# ---------------------------------------------------------------------------
if [ -n "$STAGED_PY" ]; then
  echo "mypy: type-checking staged .py files..."
  cd "$ROOT"
  # Only check the files being committed — not the entire codebase.
  # This prevents existing type debt from blocking new commits while
  # ensuring every new commit is type-safe.
  # --follow-imports=silent: only report errors in staged files, not their
  # transitive dependencies. This prevents existing type debt in imported
  # modules from blocking commits that don't touch those modules.
  echo "$STAGED_PY" | xargs uv run mypy --follow-imports=silent --no-error-summary 2>&1
  MYPY_EXIT=$?
  if [ $MYPY_EXIT -ne 0 ]; then
    echo ""
    echo "mypy: type errors found in staged files. Fix them before committing."
    echo "  Tip: run 'uv run mypy <file>' to see details."
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# Validate MDX files (catches JSX parse errors before Mintlify)
# ---------------------------------------------------------------------------
# Collect all staged .mdx files (including newly translated ones)
ALL_STAGED_MDX=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '\.mdx$' || true)

if [ -n "$ALL_STAGED_MDX" ]; then
  VALIDATOR_DIR="$ROOT/scripts/validate-mdx"
  if [ -f "$VALIDATOR_DIR/validate.mjs" ] && command -v node >/dev/null 2>&1; then
    # Install deps on first run
    [ -d "$VALIDATOR_DIR/node_modules" ] || (cd "$VALIDATOR_DIR" && pnpm install --silent 2>/dev/null)
    echo "mdx: validating staged .mdx files..."
    # Run from validator dir so Node resolves @mdx-js/mdx; convert to absolute paths
    ABS_FILES=$(echo "$ALL_STAGED_MDX" | sed "s|^|$ROOT/|")
    (cd "$VALIDATOR_DIR" && echo "$ABS_FILES" | xargs node validate.mjs)
  fi
fi
