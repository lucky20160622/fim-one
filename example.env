# LLM API Configuration
# Supports any OpenAI-compatible API (OpenAI, DeepSeek, Qwen, Ollama, etc.)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1

# Main model — used for planning, analysis, and ReAct agent
LLM_MODEL=gpt-4o

# Fast model — used for DAG step execution (cheaper, faster)
# Falls back to LLM_MODEL if not set
FAST_LLM_MODEL=gpt-4o-mini

# Optional: Default temperature for LLM calls
LLM_TEMPERATURE=0.7

# --- Agent Execution Limits ---------------------------------------------------
# ReAct mode: max tool-call iterations per request (higher = more thorough but slower)
REACT_MAX_ITERATIONS=20

# DAG mode — step execution
MAX_CONCURRENCY=5                    # How many DAG steps can run in parallel
DAG_STEP_MAX_ITERATIONS=15           # Max tool-call iterations within each DAG step

# DAG mode — re-planning
# When the agent judges the goal was NOT achieved after a round of execution,
# it can autonomously re-plan and retry. These settings control that loop:
DAG_MAX_REPLAN_ROUNDS=3              # Max autonomous re-plan attempts (user interrupts are unlimited)
DAG_REPLAN_STOP_CONFIDENCE=0.8       # If the agent is ≥80% sure the goal CANNOT be achieved,
                                     # stop retrying instead of wasting tokens on hopeless re-plans
                                     # (0.0 = never stop early, 1.0 = stop on any failure)

# Context window configuration — set these to match your model's specs.
# The system auto-computes: input_budget = context_size - max_output - 4K reserve
# Main LLM (for planning, analysis, ReAct)
# Default sweet spot: 128K context / 64K output → 60K input budget
# LLM_CONTEXT_SIZE=128000          # Effective context cap (default: 128000)
# LLM_MAX_OUTPUT_TOKENS=64000      # Max output tokens per call (default: 64000)

# Fast LLM (for DAG step execution) — falls back to main LLM values if not set
# FAST_LLM_CONTEXT_SIZE=128000
# FAST_LLM_MAX_OUTPUT_TOKENS=64000

# Web Tools — powers web_fetch and web_search
# Jina API key (optional — works without it but rate-limited)
# Get yours at https://jina.ai/
JINA_API_KEY=

# ── v0.5 RAG & Knowledge Base ──────────────────────────────────
# Embedding (Jina jina-embeddings-v3, OpenAI-compatible)
# Uses JINA_API_KEY above by default; override with these if using a different provider:
# EMBEDDING_API_KEY=sk-your-embedding-key
# EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSION=1024

# Reranker (Jina jina-reranker-v2; requires JINA_API_KEY)
RERANKER_MODEL=jina-reranker-v2-base-multilingual

# Vector Store (LanceDB, file-based — zero external services)
# VECTOR_STORE_DIR=./data/vector_store

# MCP Servers (optional, JSON array of server configs)
# Requires: uv sync --extra mcp
# Example: [{"name": "filesystem", "command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]}]
# MCP_SERVERS=

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ── v0.4 Platform Foundation ──────────────────────────────────
# Database (SQLite default; supports PostgreSQL via asyncpg)
# DATABASE_URL=sqlite+aiosqlite:///./data/fim_agent.db

# JWT Authentication
# JWT_SECRET_KEY=change-me-in-production

# File Uploads
# UPLOADS_DIR=./uploads

# ── OAuth (optional) ──────────────────────────────────────────
# GitHub OAuth App: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Frontend URL for OAuth callback redirect
# FRONTEND_URL=http://localhost:3000
